# Server runtime
NODE_ENV=development
PORT=3001
DB_PATH=./data/farols.db
NEWS_API_KEY=

# Comma-separated frontend origins allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# Set true only if you want to allow *.vercel.app preview domains
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# Cross-site cookie setting for refresh token
# Use "none" in production when frontend and backend are on different domains
REFRESH_COOKIE_SAMESITE=lax

# JWT secrets
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
